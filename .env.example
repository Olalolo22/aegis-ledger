# ══════════════════════════════════════════════════════
# Aegis Ledger — Environment Variables
# Copy this file to .env.local and populate with real values.
# ══════════════════════════════════════════════════════

# ── Solana / Cloak (NON-CUSTODIAL — no private keys on server) ──
# Main Solana RPC endpoint
SOLANA_RPC_URL=https://api.devnet.solana.com
# Client-side RPC endpoint (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Cloak Relay URL (SDK-devnet default is https://api.devnet.cloak.ag)
CLOAK_RELAY_URL=https://api.devnet.cloak.ag

# ── Feature Flags ───────────────────────────────────
# Set to false to attempt real Cloak relay transactions.
# Even when true, the app will attempt real relay first and only
# use mock parameters as a try/catch fallback.
DEMO_MODE=true

# ── Supabase ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — never exposed to client bundles
SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis ───────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cryptography ────────────────────────────────────
# 64-char hex string (32 bytes). HKDF root for all viewing-key encryption.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠ This is the ONLY location for the master key. NEVER store it in the database.
AEGIS_MASTER_SECRET=
