# ══════════════════════════════════════════════════════
# Aegis Ledger — Environment Variables
# Copy this file to .env.local and populate with real values.
# ══════════════════════════════════════════════════════

# ── Solana / Cloak ──────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
CLOAK_RELAY_URL=https://api.cloak.ag
# Absolute path to the treasury Solana keypair JSON file
TREASURY_KEYPAIR_PATH=

# ── Supabase ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — never exposed to client bundles
SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis ───────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cryptography ────────────────────────────────────
# 64-char hex string (32 bytes). HKDF root for all viewing-key encryption.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠ This is the ONLY location for the master key. NEVER store it in the database.
AEGIS_MASTER_SECRET=
